{
  "compilerOptions": {
    /* Paramètres de base de React Native intégrés directement */
    "target": "esnext",
    "module": "esnext",
    "lib": ["esnext"],
    "allowJs": true,
    "jsx": "react-native",
    "noEmit": true,
    "isolatedModules": true,

    /* Résolution des Modules moderne */
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,

    /* Configuration des chemins absolus (Alias) */
    "baseUrl": ".",
    "paths": {
      "@assets/*": ["src/assets/*"],
      "@components/*": ["src/components/*"],
      "@screens/*": ["src/screens/*"],
      "@navigation/*": ["src/navigation/*"],
      "@services/*": ["src/services/*"],
      "@hooks/*": ["src/hooks/*"],
      "@context/*": ["src/context/*"],
      "@styles/*": ["src/styles/*"],
      "@utils/*": ["src/utils/*"],
      "@types/*": ["src/types/*"],
      "@storage/*": ["src/storage/*"],
      "@database/*": ["src/database/*"]
    },

    /* Strictitude et Sécurité du code */
    "strict": true,
    "skipLibCheck": true,
    
    /* Supprime l'avertissement de dépréciation de la version actuelle de TS */
    "ignoreDeprecations": "6.0"
  },
  "exclude": [
    "node_modules",
    "babel.config.js",
    "metro.config.js",
    "jest.config.js",
    "android",
    "ios"
  ]
}